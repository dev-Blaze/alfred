<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Minimal platform theme only — real theming (colors, typography, dark mode) is done
        entirely in Compose via AlfredTheme (ui/theme/Theme.kt). No Material Components (XML)
        library dependency is needed since this app has no XML views.
    -->
    <style name="Theme.Alfred" parent="android:Theme.Material.NoActionBar" />

    <!-- AssistFallbackActivity should never actually be seen (it finishes immediately) — fully
         transparent/translucent so an unexpected launch doesn't flash an opaque screen. -->
    <style name="Theme.Alfred.Transparent" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- MainActivity's theme: translucent so only our own bottom-sheet card is visible, not an
         opaque full-screen window, over whatever app is underneath. Both invocation paths (direct
         launch and the VoiceInteractionSession) end up showing MainActivity — see the plan's
         "Samsung side button" finding. -->
    <style name="Theme.Alfred.Overlay" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
