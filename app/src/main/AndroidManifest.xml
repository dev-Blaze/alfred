<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".AideApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.Aide">

        <!-- This is what Samsung's side-button "Digital assistant app" gesture actually launches
             (it resolves the assistant package's normal launcher Activity) — see the plan's
             "Samsung side button" finding. Styled/behaves like an overlay, not a full app. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Aide.Overlay"
            android:launchMode="singleTask"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Aide" />

        <activity
            android:name=".history.HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Aide" />

        <!-- Carries the ASSIST intent filter only so RoleManager/OEM pickers recognize this app
             as assistant-capable. Never actually launched with real content — see class doc. -->
        <activity
            android:name=".assistant.AssistFallbackActivity"
            android:exported="true"
            android:theme="@style/Theme.Aide.Transparent"
            android:excludeFromRecents="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.ASSIST" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name=".assistant.AideVoiceInteractionService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/aide_voice_interaction_service" />
        </service>

        <service
            android:name=".assistant.AideSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />

        <!-- Satisfies the voice-interaction-service's recognitionService requirement — see
             AideRecognitionService's class doc for why this is a stub, not real recognition. -->
        <service
            android:name=".assistant.AideRecognitionService"
            android:exported="true"
            android:permission="android.permission.BIND_RECOGNITION_SERVICE">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>

        <service
            android:name=".webhook.WebhookForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
